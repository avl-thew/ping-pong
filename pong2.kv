#:kivy 1.0.9

<PongBall>:
    size: 50, 50

<PongPaddle>:
    size: 30, 180

<PongGame>:
    ball: pong_ball
    player1: player_left
    player2: player_right

    canvas:
        Color:
            rgba: 1, 0.5, 0.75, 0.6
        Rectangle:
            pos: self.center_x - 2, 0
            size: 4, self.height

    Label:
        font_size: 24
        font_name: 'GameFont'
        color: 1, 0.2, 0.5, 1
        center_x: root.center_x
        top: root.top - 20
        text: "AI MODE" if root.ai_mode else "2 PLAYERS"
        bold: True

    Label:
        font_size: 70
        font_name: 'GameFont'
        color: 1, 0.2, 0.5, 1
        bold: True
        center_x: root.width/4
        top: root.top - 40
        text: str(root.player1.score)

    Label:
        font_size: 70
        font_name: 'GameFont'
        color: 1, 0.15, 0.4, 1
        bold: True
        center_x: root.width*3/4
        top: root.top - 40
        text: str(root.player2.score)

    Label:
        font_size: 32
        font_name: 'GameFont'
        color: 1, 0.3, 0.6, 1
        center_x: root.center_x
        top: root.top + 5
        text: "HELLO KITTY PONG"
        bold: True

    Label:
        font_size: 14
        font_name: 'GameFont'
        color: 1, 0.3, 0.6, 0.9
        center_x: root.center_x
        y: root.y + 10
        text: "Mouse = left paddle | Double click = AI mode | Triple click = change BG"

    PongBall:
        id: pong_ball
        center: self.parent.center

    PongPaddle:
        id: player_left
        x: root.x + 50
        center_y: root.center_y

    PongPaddle:
        id: player_right
        x: root.width - self.width - 50
        center_y: root.center_y